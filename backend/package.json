{
  "name": "support-desk",
  "version": "1.0.0",
  "description": "Support ticket  app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon backend/server.js",
    "client": "npm start --prefix frontend",
    "install-client": "cd frontend && npm install",
    "install-backend": "cd backend && npm install",
    "backend-start": "cd backend && node server.js",
    "frontend-start": "cd frontend && npm run build",
    "dev": "concurrently \"npm run server\" \"npm run client\"" 
  },
  "author": "Steven Onoja",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
